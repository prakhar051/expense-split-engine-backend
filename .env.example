# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/splitsdb?schema=public"

# Redis Cache Configuration
REDIS_URL="redis://localhost:6379"

# JWT Token Secrets (Min 10 chars)
JWT_SECRET="your_jwt_access_token_secret_string"
REFRESH_TOKEN_SECRET="your_jwt_refresh_token_secret_string"

# Server Port
PORT=5000

# Cloudinary Storage Credentials
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gemini Artificial Intelligence Key
GEMINI_API_KEY=your_gemini_api_key

# Accounting Base Currency
BASE_CURRENCY=INR

# Environment Execution
NODE_ENV=production
CLIENT_URL="http://localhost:5173"
